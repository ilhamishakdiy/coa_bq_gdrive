# =============================================================================
# Google authentication
# =============================================================================

GOOGLE_APPLICATION_CREDENTIALS=service_account/your-service-account.json

# =============================================================================
# BigQuery source
# All .sql files in this folder will be executed.
# =============================================================================

BQ_PROJECT_ID=your-bigquery-project-id
BQ_SQL_FOLDER=sql
BQ_LOCATION=

# =============================================================================
# Cloud Storage destination
# GCS_EXPORT_URI is optional. Leave it blank to generate a timestamped URI.
# When set, it must contain a wildcard, for example:
# gs://your-bucket/exports/report_*.csv
# =============================================================================

GCS_PROJECT_ID=your-gcs-project-id
GCS_BUCKET_NAME=your-gcs-bucket
GCS_EXPORT_URI=
GCS_OBJECT_PREFIX=exports/bigquery
EXPORT_FILE_NAME=bigquery_export
CSV_DELIMITER=,
STREAM_CHUNK_SIZE_MB=8
DELETE_GCS_AFTER_DRIVE_UPLOAD=false

# =============================================================================
# Google Drive destination
# Share this folder with the service account email.
# =============================================================================

DRIVE_FOLDER_ID=your-google-drive-folder-id

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=INFO

# =============================================================================
# Backward compatibility
# Optional fallback when BQ_PROJECT_ID and GCS_PROJECT_ID are the same.
# =============================================================================

GCP_PROJECT_ID=
