# =============================================================================
# Authentication
# =============================================================================

# Path to the Google service-account key file.
# Leave blank when Airflow 3.x or the runtime environment provides ADC/secrets.
GOOGLE_APPLICATION_CREDENTIALS=service_account/service-account.example.json


# =============================================================================
# BigQuery configuration
# =============================================================================

# BigQuery project that runs the export query.
BQ_PROJECT_ID=your-bigquery-project-id

# Optional BigQuery location, for example US, EU, or asia-southeast1.
BQ_LOCATION=US

# Optional SQL folder override for orchestration wrappers.
BQ_SQL_FOLDER=sql


# =============================================================================
# Google Cloud Storage configuration
# =============================================================================

# GCS project and bucket used for export files.
GCS_PROJECT_ID=your-gcs-project-id
GCS_BUCKET_NAME=your-gcs-bucket-name

# Optional explicit BigQuery export URI. Must include a wildcard when set.
# Example: gs://your-gcs-bucket-name/exports/bigquery/BD/*.csv
GCS_EXPORT_URI=

# Optional explicit GCS URI for Drive upload. Leave blank to use latest merged file.
# Example: gs://your-gcs-bucket-name/exports/bigquery_merged/BD/STORE_SKU_SALES_MONTH_BD_062026_20260703T120000Z.csv
GCS_DRIVE_SOURCE_URI=

# GCS folder prefixes for raw export shards and merged CSV files.
GCS_OBJECT_PREFIX=exports/bigquery
GCS_MERGED_OBJECT_PREFIX=exports/bigquery_merged


# CSV delimiter. Use \t for tab.
CSV_DELIMITER=,


# =============================================================================
# GCS compose and cleanup flags
# =============================================================================

# Compose BigQuery CSV shards into one final file.
COMPOSE_GCS_SHARDS=true

# Delete raw BigQuery shard files after successful compose.
DELETE_GCS_SOURCES_AFTER_COMPOSE=true

# Delete uploaded GCS file after successful Google Drive upload.
DELETE_GCS_AFTER_DRIVE_UPLOAD=false


# =============================================================================
# Google Drive configuration
# =============================================================================

# Parent Google Drive folder ID for uploaded country folders/files.
DRIVE_FOLDER_ID=your-google-drive-folder-id

# Upload stream chunk size in MB. Must produce a multiple of 256 KiB.
STREAM_CHUNK_SIZE_MB=8


# =============================================================================
# Runtime and Airflow 3.x configuration
# =============================================================================

# Logging level used by local scripts and Airflow task logs.
LOG_LEVEL=INFO

# Backward-compatible fallback project ID.
# Prefer BQ_PROJECT_ID and GCS_PROJECT_ID for new Airflow 3.x DAGs.
GCP_PROJECT_ID=
